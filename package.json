{
  "name": "heatmap",
  "version": "1.10.3",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:fresh": "electron . --fresh",
    "build": "electron-builder --win portable",
    "dist": "electron-builder --win nsis"
  },
  "description": "Job Application Heatmap Widget",
  "build": {
    "appId": "com.heatmap.widget",
    "productName": "Heatmap",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "asarUnpack": [
      "**/node_modules/sql.js/dist/*.wasm"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Ahmed-Amamou",
      "repo": "Heatmap"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  }
}
